# Per-host info for the devnet docker overlay. Copy to hosts.env
# and fill in. All addresses must be valid Octra wallet addresses
# corresponding to the *.key files you mount under
# $HOST_DEVNET_DIR/node{1,2,3}/.

# Three operator validator wallets — each must be funded via the
# faucet (https://faucet.octra.network) BEFORE register.
NODE1_VALIDATOR_ADDR=oct__node1_wallet_addr__
NODE2_VALIDATOR_ADDR=oct__node2_wallet_addr__
NODE3_VALIDATOR_ADDR=oct__node3_wallet_addr__

# Publicly-reachable endpoint each node binds. For a single-host
# docker setup, use the host's public IP + the bound port.
NODE1_PUBLIC_ENDPOINT=node1.example.com:51820
NODE2_PUBLIC_ENDPOINT=node2.example.com:51821
NODE3_PUBLIC_ENDPOINT=node3.example.com:51822

# Per-node price + region. Defaults to 100 OU/MB / "test" if unset.
NODE1_PRICE_PER_MB=100
NODE2_PRICE_PER_MB=100
NODE3_PRICE_PER_MB=100
NODE1_REGION=test-eu
NODE2_REGION=test-us
NODE3_REGION=test-ap

# Client wallet that opens sessions. Must be funded + must be a
# member of any tailnet it opens against.
CLIENT_ADDR=oct__client_wallet_addr__
