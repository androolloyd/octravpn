NODE2_VALIDATOR_ADDR=octHYjn38hTtT43kDzQFFr5kxN3A4s1kVQZiey343KfRDS7
NODE3_VALIDATOR_ADDR=oct5dVy5bqoxz55Qyw5ELyfvBXV3r33Qsxq6XVwFMChrAZw

# Publicly-reachable endpoint each node binds. Edit for your host —
# substitute your VPS IP/hostname + the port docker exposes.
NODE1_PUBLIC_ENDPOINT=node1.example.com:51820
NODE2_PUBLIC_ENDPOINT=node2.example.com:51821
NODE3_PUBLIC_ENDPOINT=node3.example.com:51822

# Per-node price + region. Override per location.
NODE1_PRICE_PER_MB=100
NODE2_PRICE_PER_MB=100
NODE3_PRICE_PER_MB=100
NODE1_REGION=eu-test
NODE2_REGION=us-test
NODE3_REGION=ap-test

# Client wallet that opens sessions. Must be funded + must be a
# member of any tailnet it opens against.
