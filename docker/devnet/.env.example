# OctraVPN devnet env. Copy to .env and fill in.
#
# Octra runs two distinct chains:
#   * Mainnet — `https://octra.network/rpc` (real OCT; don't use for testing)
#   * Devnet  — `https://devnet.octrascan.io/rpc` (faucet-funded; use this)
# Devnet is what the faucet (https://faucet.octra.network/) drops to.
OCTRA_RPC_URL=https://devnet.octrascan.io/rpc

# Fill in after `./docker/devnet/deploy.sh` (or after a manual
# deploy via the Octra web client). Leave the placeholder while
# bootstrapping and the compose up will refuse to start.
PROGRAM_ADDR=oct__DEPLOYED_PROGRAM_ADDRESS__

# Per-host directory containing rendered configs + wallet keys.
# Layout:
#   $HOST_DEVNET_DIR/node1/node.toml
#   $HOST_DEVNET_DIR/node1/wallet.key       (0600)
#   $HOST_DEVNET_DIR/node1/wg.key           (0600)
#   $HOST_DEVNET_DIR/node2/{node.toml,wallet.key,wg.key}
#   $HOST_DEVNET_DIR/node3/{node.toml,wallet.key,wg.key}
#   $HOST_DEVNET_DIR/client/{client.toml,wallet.key}
#
# Default is ./docker/devnet/state — rendered by
# `./docker/devnet/render-configs.sh`.
HOST_DEVNET_DIR=./docker/devnet/state
