# OctraVPN testnet / mainnet-alpha env. Copy to .env and fill in.
#
# As of 2026-05, Octra's "mainnet alpha" is the only live network —
# there's no separate testnet RPC (testnet.octra.network does not
# resolve). The faucet is still live for funding test addresses.
#
# RPC reachable through either of:
#   https://octra.network/rpc       (primary)
#   https://octrascan.io/rpc        (proxy via the explorer)
OCTRA_RPC_URL=https://octra.network/rpc

# Fill in after `./docker/testnet/deploy.sh` (or after a manual
# deploy via the Octra web client). Leave the placeholder while
# bootstrapping and the compose up will refuse to start.
PROGRAM_ADDR=oct__DEPLOYED_PROGRAM_ADDRESS__

# Per-host directory containing rendered configs + wallet keys.
# Layout:
#   $HOST_TESTNET_DIR/node1/node.toml
#   $HOST_TESTNET_DIR/node1/wallet.key       (0600)
#   $HOST_TESTNET_DIR/node1/wg.key           (0600)
#   $HOST_TESTNET_DIR/node2/{node.toml,wallet.key,wg.key}
#   $HOST_TESTNET_DIR/node3/{node.toml,wallet.key,wg.key}
#   $HOST_TESTNET_DIR/client/{client.toml,wallet.key}
#
# Default is ./docker/testnet/state — rendered by
# `./docker/testnet/render-configs.sh`.
HOST_TESTNET_DIR=./docker/testnet/state
