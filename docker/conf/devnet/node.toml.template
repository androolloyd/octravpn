# Template — substitute ${PROGRAM_ADDR} and ${VALIDATOR_ADDR} via
# `envsubst` before mounting. See docker/devnet/README.md.
[chain]
rpc_url             = "${OCTRA_RPC_URL}"
program_addr        = "${PROGRAM_ADDR}"
validator_addr      = "${VALIDATOR_ADDR}"
wallet_secret_path  = "/etc/octravpn/wallet.key"

[tunnel]
public_endpoint     = "${PUBLIC_ENDPOINT}"
listen              = "0.0.0.0:51820"
wg_secret_path      = "/etc/octravpn/wg.key"

[pricing]
price_per_mb        = ${PRICE_PER_MB}
region              = "${REGION}"

[control]
listen              = "0.0.0.0:51821"
audit_dir           = "/tmp/octravpn-audit"

# v4 relay-settlement caller path. Default-off for ordinary devnet
# nodes; docker/devnet/v4-relay-e2e.sh renders a generated node1
# config with this enabled for the relay-claim smoke.
[control.relay]
enabled             = false
relay_expiry_epochs = 200

[attestation]
poll_interval_secs  = 60

# PVAC sidecar (HFHE / encrypted-earnings path). Off by default so
# existing devnet runs don't need the C++ toolchain. To enable:
#   1. `cd pvac-sidecar && make` (or use the Dockerfile) so the
#      binary lands at `octra-pvac-sidecar`.
#   2. Set `enabled = true` and (if not running from the repo root)
#      override `binary_path` to the deployed location.
# If `enabled = true` but the binary is missing, the node logs a
# warning at boot and continues without HFHE — boot does NOT fail.
[pvac]
enabled              = false
binary_path          = "./pvac-sidecar/octra-pvac-sidecar"
restart_backoff_ms   = 250
request_timeout_secs = 30
