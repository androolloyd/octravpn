FROM octravpn-builder:latest AS builder

FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates iproute2 curl && rm -rf /var/lib/apt/lists/*

COPY --from=builder /work/octra/target/release/octravpn /usr/local/bin/octravpn

RUN useradd -r -s /bin/false octravpn
USER octravpn

ENTRYPOINT ["/usr/local/bin/octravpn"]
CMD ["--config", "/etc/octravpn/client.toml", "identity"]
