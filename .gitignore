/target
**/*.rs.bk
*.pem
*.key
.envrc
.env
.DS_Store
/proofs/tla/*.toolbox
/proofs/tla/states
/proofs/lean/build
/proofs/lean/.lake
/proofs/tamarin/*.png
/proofs/tamarin/*.dot
node_modules/
.idea/
.claude/worktrees/

# fuzz build artifacts
fuzz/target/
fuzz/Cargo.lock
# Corpus + artifacts are produced by libfuzzer runs and persisted via
# the CI cache between nightly runs; tracking them in git would balloon
# the repo. The directories themselves are kept (via `.gitkeep`) so the
# cache restore-keys have somewhere to land.
fuzz/corpus/*/*
!fuzz/corpus/*/.gitkeep
fuzz/artifacts/

# pvac-sidecar build outputs
pvac-sidecar/build/
pvac-sidecar/octra-pvac-sidecar

# testnet operator state (sealed keys, rendered configs, ceremony output)
/deploy/testnet/.env.testnet
/deploy/testnet/testnet-params.toml
/deploy/testnet/state/
/operator-state/

# 3-node mesh demo runtime state (TLS cert, audit dir; regenerated on
# every bringup).
/demo/.mesh-state/

# Generated demo FHE private keys. Public keys and sample node configs
# may be tracked; private ceremony output must stay local.
/docker/conf/node*/fhe.sk

# Bench snapshots are committed (see docs/performance-limitations.md §7).
# `target/criterion/` (under the already-ignored `/target`) holds
# per-run criterion output; only the curated JSON under
# `bench-snapshots/` is tracked.
!bench-snapshots/
!bench-snapshots/*.json
# Audit fixture demo state — regenerated by demo/lib/audit-fixture-bringup.sh
/demo/.audit-fixture/
