/target
**/*.rs.bk
*.pem
*.key
.envrc
.env
.DS_Store
/proofs/tla/*.toolbox
/proofs/tla/states
/proofs/lean/build
/proofs/lean/.lake
/proofs/tamarin/*.png
/proofs/tamarin/*.dot
node_modules/
.idea/
.claude/worktrees/

# fuzz build artifacts
fuzz/target/
fuzz/Cargo.lock
# Corpus + artifacts are produced by libfuzzer runs and persisted via
# the CI cache between nightly runs; tracking them in git would balloon
# the repo. The directories themselves are kept (via `.gitkeep`) so the
# cache restore-keys have somewhere to land.
fuzz/corpus/*/*
!fuzz/corpus/*/.gitkeep
fuzz/artifacts/

# pvac-sidecar build outputs
pvac-sidecar/build/
pvac-sidecar/octra-pvac-sidecar

# testnet operator state (sealed keys, rendered configs, ceremony output)
/deploy/testnet/.env.testnet
/deploy/testnet/testnet-params.toml
/deploy/testnet/state/
/operator-state/

# 3-node mesh demo runtime state (TLS cert, audit dir; regenerated on
# every bringup).
/demo/.mesh-state/

# Generated demo FHE private keys. Public keys and sample node configs
# may be tracked; private ceremony output must stay local.
/docker/conf/node*/fhe.sk

# Demo nodes (docker/conf/demo-node{1,2,3}) use known-stub wallet/wg
# keypairs — they do sealed-only reads against devnet and never sign
# chain txs. The keys are deterministic 32-byte hex placeholders;
# tracking them keeps CI's docker compose up from failing on missing
# mount targets. NOT real wallets.
!/docker/conf/demo-node*/wallet.key
!/docker/conf/demo-node*/wg.key

# Bench snapshots are committed (see docs/performance-limitations.md §7).
# `target/criterion/` (under the already-ignored `/target`) holds
# per-run criterion output; only the curated JSON under
# `bench-snapshots/` is tracked.
!bench-snapshots/
!bench-snapshots/*.json
# Audit fixture demo state — regenerated by demo/lib/audit-fixture-bringup.sh
/demo/.audit-fixture/

# Devnet per-tape runtime state seeded by demo/lib/devnet-circle-deploy.sh.
# Track only the public circle-id.txt; ignore everything else (wallets,
# keys, ephemeral fixture dirs).
/demo/state/*
!/demo/state/devnet/
/demo/state/devnet/*
!/demo/state/devnet/circle-id.txt

# Portal-container runtime config + dummy wallet rendered by
# demo/lib/portal-container-bringup.sh. Regenerated on every run.
/demo/.portal-state/
