# Generated by scripts/ceremony/mainnet-deploy.sh on every dry-run.
# Re-derivable from ceremony/mainnet-params.toml + program/main-v3.aml
# so we don't commit the regen output. The post-ceremony attestation
# (docs/mainnet-ceremony.md §3) copies the final canonical artifacts
# into a separately-committed attestation file.
build/

# Signer secrets — committed pubkeys + sigs only; sealed keys never.
signers/*.key.sealed
signers/*.key

# Project-local override of the example params (mainnet values may
# include addresses that should not surface in public review until
# the ceremony's PR; check in via PR).
mainnet-params.toml
