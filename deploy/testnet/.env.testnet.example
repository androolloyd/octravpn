# OctraVPN testnet environment — copy to deploy/testnet/.env.testnet
# and replace every PLACEHOLDER_* value before bringing up the stack.
#
# This file is committed; the real .env.testnet is gitignored.
# scripts/testnet/bootstrap.sh will refuse to start if any
# PLACEHOLDER_ value remains.

# ---------------------------------------------------------------------
# Chain target
# ---------------------------------------------------------------------
# Public Octra testnet RPC. There is no "octra testnet" RPC yet —
# until that exists, point this at the devnet RPC and set CHAIN_ID
# accordingly. The bootstrap script REFUSES to broadcast against any
# mainnet RPC.
OCTRA_RPC_URL=https://devnet.octrascan.io/rpc
CHAIN_ID=octra-testnet
PROGRAM_ADDR=PLACEHOLDER_PROGRAM_ADDR

# ---------------------------------------------------------------------
# Validator endpoints — must be PUBLIC + DNS-routable
# ---------------------------------------------------------------------
# These are the WireGuard endpoints peers will dial. Each MUST be a
# real DNS name (or a public IP) reachable from the open internet.
# Loopback / docker-internal addresses are rejected by health-check.
VALIDATOR1_PUBLIC_ENDPOINT=PLACEHOLDER_tn1.example.com:51820
VALIDATOR1_ADDR=PLACEHOLDER_oct_validator1_addr
VALIDATOR1_REGION=test-eu
VALIDATOR1_PRICE_PER_MB=100
VALIDATOR1_WG_PORT=51820
VALIDATOR1_CONTROL_PORT=51821

VALIDATOR2_PUBLIC_ENDPOINT=PLACEHOLDER_tn2.example.com:51830
VALIDATOR2_ADDR=PLACEHOLDER_oct_validator2_addr
VALIDATOR2_REGION=test-us
VALIDATOR2_PRICE_PER_MB=100
VALIDATOR2_WG_PORT=51830
VALIDATOR2_CONTROL_PORT=51822

VALIDATOR3_PUBLIC_ENDPOINT=PLACEHOLDER_tn3.example.com:51840
VALIDATOR3_ADDR=PLACEHOLDER_oct_validator3_addr
VALIDATOR3_REGION=test-ap
VALIDATOR3_PRICE_PER_MB=100
VALIDATOR3_WG_PORT=51840
VALIDATOR3_CONTROL_PORT=51823

# ---------------------------------------------------------------------
# Mesh control plane
# ---------------------------------------------------------------------
MESH_CONTROL_PORT=8085
MESH_CONTROL_URL=https://mesh.testnet.example.com
# 2-of-3 multisig (testnet default; smaller than mainnet 3-of-5). The
# multisig address is produced by scripts/testnet/genesis-wallets.sh
# and is the only key allowed to push revocations to mesh-control.
OPERATOR_MULTISIG_ADDR=PLACEHOLDER_oct_multisig_addr
OPERATOR_MULTISIG_THRESHOLD=2

# ---------------------------------------------------------------------
# DERP relay
# ---------------------------------------------------------------------
DERP_HOSTNAME=PLACEHOLDER_derp.testnet.example.com
DERP_URL=https://PLACEHOLDER_derp.testnet.example.com
DERP_HTTP_PORT=3340
DERP_STUN_PORT=3478

# ---------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION=30d
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=PLACEHOLDER_strong_grafana_password

# ---------------------------------------------------------------------
# Sealed-key passphrase (P1-6)
# ---------------------------------------------------------------------
# Required because testnet uses sealed wallet bundles by default.
# Generate with: openssl rand -hex 32
# Keep this OUT of git and OUT of CI logs — pass via secret manager.
OCTRAVPN_KEY_PASSPHRASE=PLACEHOLDER_sealed_key_passphrase

# ---------------------------------------------------------------------
# Layout knobs
# ---------------------------------------------------------------------
TESTNET_CONFIG_DIR=./deploy/testnet/state
TESTNET_SUBNET=172.28.0.0/16
RUST_LOG=info,octravpn_node=info
